<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="actor_view_tree" model="ir.ui.view">
            <field name="name">actor_view_tree</field>
            <field name="model">dvd_rental.actor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="first_name" decoration-bf="1"/>
                    <field name="last_name" decoration-bf="1"/>
                    <field name="film_ids" widget="many2many_tags" />
                </tree>
            </field>
        </record>
        <record id="actor_view_form" model="ir.ui.view">
            <field name="name">actor_view_form</field>
            <field name="model">dvd_rental.actor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="first_name" placeholder="eg.first name....."/>
                            <field name="last_name" placeholder="eg.first name....."/>
                            <field name="film_ids" widget="many2many_tags"  options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                        <field name="activity_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="actor_view_menu_action" model="ir.actions.act_window">
            <field name="name">category_view_menu_action</field>
            <field name="res_model">dvd_rental.actor</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Record !
                </p>
            </field>
        </record>
        <menuitem
            id="actor_view_menu"
            name="Actors"
            sequence="2"
            parent="catalog_main_menu"
            action="actor_view_menu_action"
        />
    </data>
</odoo>