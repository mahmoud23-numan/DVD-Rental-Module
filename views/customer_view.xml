<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="customer_view_tree" model="ir.ui.view">
            <field name="name">customer_view_tree</field>
            <field name="model">dvd_rental.customer</field>
            <field name="arch" type="xml">
                <tree decoration-bf="1">
                    <field name="first_name"/>
                    <field name="last_name"/>
                    <field name="email"/>
                    <field name="store_id" widget="badge"/>
                    <field name="active_bool"/>
                    <field name="address_id" optional="hide"/>
                    <field name="user_id" optional="hide"/>
                </tree>
            </field>
        </record>
        <record id="customer_view_form" model="ir.ui.view">
            <field name="name">customer_view_form</field>
            <field name="model">dvd_rental.customer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="get_all_rentals" icon="fa-star"
                                    class="oe_stat_button" type="object">
                                <div class="o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="rental_count"/>
                                    </span>
                                    <span class="o_stat_text"> Rental</span>
                                </div>
                            </button>
                        </div>
                        <group>
                            <group string="Imp Info!">
                                <field name="first_name"/>
                                <field name="last_name"/>
                                <field name="email"/>
                                <field name="active_bool"/>
                            </group>
                            <group string="Additional Info!">
                                <field name="address_id"/>
                                <field name="store_id"/>
                                <field name="user_id"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                        <field name="activity_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="customer_view_menu_action" model="ir.actions.act_window">
            <field name="name">customer_view_menu_action</field>
            <field name="res_model">dvd_rental.customer</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Record !
                </p>
            </field>
        </record>
        <menuitem
            id="customer_view_menu"
            name="Customers"
            sequence="1"
            parent="customers_main_menu"
            action="customer_view_menu_action"
        />
    </data>
</odoo>