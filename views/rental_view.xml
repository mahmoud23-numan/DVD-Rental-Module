<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="ir_cron_check_date_of_rental" model="ir.cron">
        <field name="name">Check Overdue</field>
        <field name="model_id" ref="dvd_rental.model_dvd_rental_rental"/>
        <field name="state">code</field>
        <field name="code">
            model.check_date_of_rental()
        </field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
        <record id="rental_view_graph" model="ir.ui.view">
            <field name="name">rental.view.graph</field>
            <field name="model">dvd_rental.rental</field>
            <field name="arch" type="xml">
                <graph string="Rental Analysis" type="pie" sample="1">
                    <field name="state" type="row"/>
                    <field name="amount" type="measure"/>
                </graph>
            </field>
        </record>
        <record id="rental_view_graph" model="ir.ui.view">
            <field name="name">rental.view.graph</field>
            <field name="model">dvd_rental.rental</field>
            <field name="arch" type="xml">
                <graph string="Rental Analysis" type="bar" sample="1">
                    <field name="state" type="row"/>
                    <field name="amount" type="measure"/>
                </graph>
            </field>
        </record>
        <record id="rental_view_tree" model="ir.ui.view">
            <field name="name">rental_view_tree</field>
            <field name="model">dvd_rental.rental</field>
            <field name="arch" type="xml">
                <tree decoration-danger="state not in  'draft,returned'" decoration-muted="state == 'returned'" >
                    <field name="rental_date"/>
                    <field name="return_date"/>
                    <field name="number_of_days_rental"/>
                    <field name="amount"/>
                    <field name="currency_id" invisible="0" optional="hide"/>
                    <field name="inventory_id"/>
                    <field name="customer_id"/>
                    <field name="staff_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>
        <record id="rental_view_form" model="ir.ui.view">
            <field name="name">rental_view_form</field>
            <field name="model">dvd_rental.rental</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="%(dvd_rental.create_payment_wizard_action)d" type="action"
                                string="Create Payment" class="btn-success" invisible="state != 'draft'"/>
                        <button name="action_returned" string="Returned" type="object"
                                class="btn-primary" invisible="state == 'draft' or state == 'returned'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Overdue" bg_color="text-bg-danger" invisible="state != 'overdue' "/>
                        <widget name="web_ribbon" title="Returned" bg_color="text-bg-info" invisible="state != 'returned' "/>
                        <widget name="web_ribbon" title="Borrowed" bg_color="text-bg-success" invisible="state != 'borrowed' "/>
                        <group>
                            <field name="rental_date" readonly="state != 'draft'"/>
                            <field name="return_date" readonly="state != 'draft'"/>
                            <field name="number_of_days_rental"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="inventory_id" readonly="state != 'draft'" options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                            <field name="customer_id" readonly="state != 'draft'" options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                            <field name="staff_id" readonly="state != 'draft'" options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                        <field name="activity_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="rental_view_menu_action" model="ir.actions.act_window">
            <field name="name">rental_view_menu_action</field>
            <field name="res_model" >dvd_rental.rental</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="help" type="xml">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Record!
                </p>
            </field>
        </record>
        <menuitem
            id="rental_view_menu"
            name="Rentals"
            sequence="1"
            parent="rentals_main_menu"
            action="rental_view_menu_action"
            />
    </data>
</odoo>