<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="city_view_tree" model="ir.ui.view">
            <field name="name">city_view_tree</field>
            <field name="model">dvd_rental.city</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="country_id"/>
                    <field name="state_id"/>
                </tree>
            </field>
        </record>
        <record id="city_view_form" model="ir.ui.view">
            <field name="name">city_view_form</field>
            <field name="model">dvd_rental.city</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group string="Imp Info!">
                                <field name="country_id"/>
                                <field name="res_country_id" invisible="1"/>
                                <field name="state_id"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                        <field name="activity_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="city_view_menu_action" model="ir.actions.act_window">
            <field name="name">city_view_menu_action</field>
            <field name="res_model">dvd_rental.city</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Record !
                </p>
            </field>
        </record>
        <menuitem
            id="city_view_menu"
            name="Cities"
            sequence="3"
            parent="customers_main_menu"
            action="city_view_menu_action"
        />
    </data>
</odoo>