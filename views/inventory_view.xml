<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record model="ir.ui.view" id="inventory_view_tree">
            <field name="name">inventory_view_tree</field>
            <field name="model">dvd_rental.inventory</field>
            <field name="arch" type="xml">
                <tree decoration-bf="1">
                    <field name="film_id"  widget="badge" />
                    <field name="store_id" widget="badge"/>
                </tree>
            </field>
        </record>
        <record model="ir.ui.view" id="inventory_view_form">
            <field name="name">inventory_view_form</field>
            <field name="model">dvd_rental.inventory</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="film_id"  options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                            <field name="store_id"  options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                        <field name="activity_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <record model="ir.ui.view" id="inventory_view_search">
            <field name="name">inventory_view_search</field>
            <field name="model">dvd_rental.inventory</field>
            <field name="arch" type="xml">
                <search>
                    <filter name="group_by_store" string="Store" context="{'group_by':'store_id'}"/>
                </search>
            </field>
        </record>
        <record id="inventory_view_menu_action" model="ir.actions.act_window">
            <field name="name">store_view_menu_action</field>
            <field name="res_model">dvd_rental.inventory</field>
            <field name="context">{'search_default_group_by_store': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Record!
                </p>
            </field>
        </record>
        <menuitem
            id="inventory_view_menu"
            name="Inventory"
            sequence="1"
            parent="inventory_main_menu"
            action="inventory_view_menu_action"/>
    </data>
</odoo>