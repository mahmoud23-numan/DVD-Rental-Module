<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <template id="payment_report_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="text-center" style="border-bottom: 2px solid black; margin-bottom: 20px;">
                                <h2>Payment Receipt</h2>
                            </div>

                            <div class="row mt32 mb32">
                                <div class="col-6">
                                    <strong>Customer:</strong>
                                    <p t-field="o.customer_id.display_name"/>
                                </div>
                                <div class="col-6 text-end">
                                    <strong>Date:</strong>
                                    <p t-field="o.payment_date"/>
                                </div>
                            </div>

                            <table class="table table-sm o_main_table mt16">
                                <thead>
                                    <tr class="bg-light">
                                        <th>Rental Reference</th>
                                        <th>Staff Member</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><span t-field="o.rental_id"/></td>
                                        <td><span t-field="o.staff_id.first_name"/></td>
                                        <td class="text-end">
                                            <span t-field="o.amount"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="row justify-content-end">
                                <div class="col-4">
                                    <table class="table table-sm">
                                        <tr class="border-black o_total">
                                            <td><strong>Total Paid</strong></td>
                                            <td class="text-end">
                                                <span t-field="o.amount"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
        <record id="payment_report_action" model="ir.actions.report">
            <field name="name">Payment Report</field>
            <field name="model">dvd_rental.payment</field>
            <field name="report_type">qweb-pdf</field>
            <field name="binding_model_id" ref="model_dvd_rental_payment"/>
            <field name="binding_type">report</field>
            <field name="report_name">dvd_rental.payment_report_template</field>
        </record>
    </data>
</odoo>