<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="create_payment_wizard_view" model="ir.ui.view">
            <field name="name">create_payment_wizard_form</field>
            <field name="model">wizard.create_payment_wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="customer_id" readonly="1" options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                        <field name="staff_id" readonly="1" options="{'no_open':True,'no_create':True,'no_create_edit':True}" />
                        <field name="rental_id" readonly="1" options="{'no_open':True,'no_create':True,'no_create_edit':True}"/>
                        <field name="amount" readonly="1"/>
                        <field name="payment_date" readonly="1"/>
                    </group>
                    <footer>
                        <button string="Confirm" name="action_confirm_payment" type="object"
                                class="btn-primary"/>
                        <button string="Cancel"  special="cancel" class="btn-danger"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="create_payment_wizard_action" model="ir.actions.act_window">
            <field name="name">Create Payment</field>
            <field name="res_model">wizard.create_payment_wizard</field>
            <field name="target">new</field>
            <field name="view_mode">form</field>
        </record>
    </data>
</odoo>